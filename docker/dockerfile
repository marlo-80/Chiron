# =============================================================================
# Dockerfile – Chiron RAG Pipeline (offline PubMed retrieval & indexing)
# =============================================================================
# 1. CLEAN PYTHON 3.11 BASE IMAGE
FROM python:3.11-bookworm

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# 2. SYSTEM PACKAGES FOR C COMPILATION
RUN apt-get update && apt-get install -y --no-install-recommends \
    libxml2-dev \
    libxslt-dev \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# 3. UPGRADE PIP
RUN pip install --no-cache-dir --upgrade pip

# 4. PYTORCH WITH CUDA 12.6 SUPPORT
COPY requirements.txt .
RUN pip install --no-cache-dir \
    torch==2.6.0+cu126 \
    torchvision==0.21.0+cu126 \
    torchaudio==2.6.0+cu126 \
    --index-url https://download.pytorch.org/whl/cu126

# 5. PROJECT DEPENDENCIES
RUN pip install --no-cache-dir -r requirements.txt

# 6. SCISPACY LANGUAGE MODEL
RUN pip install --no-cache-dir https://s3-us-west-2.amazonaws.com/ai2-s2-scispacy/releases/v0.5.4/en_core_sci_sm-0.5.4.tar.gz

# 7. ADD PROJECT SOURCES TO PYTHONPATH
WORKDIR /app
RUN git clone https://github.com/open-webui/pipelines.git . && \
    pip install --no-cache-dir -r requirements-minimum.txt

# Copy your validated pipeline script into the autoload folder
COPY src/chiron_pipeline.py /app/pipelines/chiron_pipeline.py

# Make sure Python can find your source code
ENV PYTHONPATH=/app:/app/src

# Expose the port Open WebUI will connect to
EXPOSE 9099

# 8. Start the pipelines server
CMD ["bash", "start.sh"]